---
services:
  arangodb:
    image: arangodb/arangodb:latest
    container_name: arangodb
    hostname: arangodb
    environment:
      ARANGO_ROOT_PASSWORD: discogsography
    ports:
      - "8529:8529"
    volumes:
      - arangodb_data:/var/lib/arangodb3
    healthcheck:
      test: ["CMD", "arangosh", "--server.password", "discogsography", "--javascript.execute-string", "db._version()"]
      interval: 10s
      timeout: 5s
      retries: 10
      start_period: 30s
    restart: unless-stopped

volumes:
  arangodb_data:
