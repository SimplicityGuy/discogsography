---
services:
  falkordb:
    image: falkordb/falkordb:latest
    container_name: falkordb
    hostname: falkordb
    ports:
      - "6379:6379"
    volumes:
      - falkordb_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
    restart: unless-stopped

volumes:
  falkordb_data:
